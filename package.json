{
  "name": "enterprise-saas-starter-kit",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:railway": "pnpm clean:force && pnpm --filter @enterprise/database build && pnpm --filter api build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean && rm -rf .turbo apps/web/.next apps/api/dist apps/gateway/dist packages/database/dist",
    "clean:force": "pnpm clean && rm -rf node_modules",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:push": "pnpm --filter @enterprise/database db:push",
    "db:seed": "pnpm --filter @enterprise/database db:seed"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
