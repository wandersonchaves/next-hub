generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model User {
  id           String   @id @default(cuid())
  clerkId      String?  @unique
  name         String?
  email        String   @unique
  passwordHash String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships       Member[]
  invitesSent       Invite[]               @relation("InviteSender")
  auditLogs         AuditLog[]
  accounts          Account[]
  organizationUnits UserOrganizationUnit[]
}

enum UnitType {
  HEALTH
  PET
  CORE
}

enum UnitRole {
  ORGANIZATION_ADMIN
  UNIT_MANAGER
  OPERATIONAL_STAFF
}

model Unit {
  id             String   @id @default(cuid())
  name           String
  type           UnitType @default(CORE)
  organizationId String
  metadata       Json?    @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads           Lead[]
  appointments    Appointment[]
  suggestedMessages SuggestedMessage[]
  interactions    Interaction[]
  userPermissions UserOrganizationUnit[]
  procedures      Procedure[]
  pets            Pet[]
  petServices     PetService[]

  @@index([organizationId])
}

model UserOrganizationUnit {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  unitId         String
  role           UnitRole @default(OPERATIONAL_STAFF)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId])
  @@index([userId])
  @@index([unitId])
  @@index([organizationId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model UserInvitation {
  id             String           @id @default(cuid())
  email          String
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  organizationId String
  unitIds        String[]         @default([])
  role           UnitRole         @default(OPERATIONAL_STAFF)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
}

model Procedure {
  id                String   @id @default(cuid())
  name              String
  durationInMinutes Int
  price             Decimal
  organizationId    String
  unitId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
  @@index([unitId])
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
  GIANT
}

enum PetServiceType {
  BATH
  GROOMING
  VET
}

model Pet {
  id             String    @id @default(cuid())
  name           String
  breed          String?
  size           PetSize   @default(MEDIUM)
  weight         Float?
  lastBathAt     DateTime?
  tutorId        String
  organizationId String
  unitId         String
  metadata       Json?     @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([unitId])
  @@index([tutorId])
}

model PetService {
  id                String         @id @default(cuid())
  name              String
  price             Decimal
  durationInMinutes Int
  type              PetServiceType @default(BATH)
  organizationId    String
  unitId            String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([unitId])
}

model Lead {
  id                String   @id @default(cuid())
  name              String
  email             String?
  phone             String
  status            String   @default("NEW")
  score             Int      @default(0)
  industry          String?
  pendingMessage    String?
  lastInteractionAt DateTime @default(now())
  unitId            String
  organizationId    String
  metadata          Json?    @default("{}")
  isPending         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  unit              Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline          LeadPipeline?
  appointments      Appointment[]
  suggestedMessages SuggestedMessage[]
  interactions      Interaction[]

  @@unique([phone, organizationId])
  @@index([organizationId])
  @@index([unitId])
}

model Interaction {
  id             String   @id @default(cuid())
  externalId     String?  @unique // WhatsApp Message ID
  content        String
  type           String   // INBOUND, OUTBOUND
  leadId         String
  unitId         String
  organizationId String
  createdAt      DateTime @default(now())

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([organizationId])
  @@index([unitId])
  @@index([externalId])
}

model SuggestedMessage {
  id             String   @id @default(cuid())
  content        String
  status         String   @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, REJECTED
  leadId         String
  unitId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([organizationId])
  @@index([unitId])
}

model Appointment {
  id             String   @id @default(cuid())
  title          String
  startTime      DateTime
  endTime        DateTime
  googleEventId  String?
  status         String   @default("SCHEDULED")
  leadId         String
  procedureId    String?
  unitId         String
  organizationId String
  metadata       Json?    @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  procedure    Procedure?   @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([unitId])
  @@index([leadId])
  @@index([procedureId])
}

model Account {
  id                String @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  BILLING
  VIEWER
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum AutomationMode {
  COPILOT
  FULL_AUTOPILOT
}

model Organization {
  id             String             @id @default(cuid())
  clerkId    String?            @unique
  name       String
  slug       String             @unique
  avatarUrl  String?
  brandColor String?            @default("#0f172a")
  logoUrl    String?
  status     OrganizationStatus @default(ACTIVE)
  automationMode AutomationMode     @default(COPILOT)
  enableAutopilot Boolean           @default(false)
  usageCount     Int                @default(0)
  metadata       Json?              @default("{}")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  enabledModules String[] @default(["CORE"])

  members             Member[]
  invites             Invite[]
  subscription        Subscription?
  documents           Document[]
  webhooks            Webhook[]
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  plugins             Plugin[]
  installedExtensions InstalledExtension[]
  workflows           Workflow[]
  units               Unit[]
  userOrganizationUnits UserOrganizationUnit[]
  userInvitations     UserInvitation[]
  leads               Lead[]
  leadPipelines       LeadPipeline[]
  appointments        Appointment[]
  suggestedMessages   SuggestedMessage[]
  interactions        Interaction[]
  procedures          Procedure[]
  pets                Pet[]
  petServices         PetService[]
}

model LeadPipeline {
  id             String   @id @default(cuid())
  leadId         String   @unique
  stage          String   // e.g., 'REUNIAO_MARCADA'
  estimatedValue Decimal  @default(0)
  organizationId String
  updatedAt      DateTime @updatedAt

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}


model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Member {
  id             String @id @default(cuid())
  role           Role   @default(MEMBER)
  organizationId String
  userId         String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model Document {
  id             String                       @id @default(cuid())
  content        String
  embedding      Unsupported("vector(1536)")?
  organizationId String
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  role      Role     @default(MEMBER)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  organizationId String
  authorId       String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User?        @relation("InviteSender", fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
}

model Webhook {
  id             String   @id @default(cuid())
  url            String
  secret         String
  events         String[]
  active         Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ApiKey {
  id             String   @id @default(cuid())
  key            String   @unique
  displayKey     String
  name           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String
  entity         String
  entityId       String?
  userId         String
  organizationId String
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
}

model Plugin {
  id             String   @id @default(cuid())
  name           String
  description    String?
  code           String
  events         String[]
  active         Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model MarketplaceExtension {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  author       String
  iconUrl      String?
  configSchema Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  installations InstalledExtension[]
}

model InstalledExtension {
  id             String   @id @default(cuid())
  extensionId    String
  organizationId String
  config         Json?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  extension    MarketplaceExtension @relation(fields: [extensionId], references: [id])
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([extensionId, organizationId])
}

model Workflow {
  id             String   @id @default(cuid())
  name           String
  triggerEvent   String
  active         Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps        WorkflowStep[]
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WorkflowStep {
  id         String @id @default(cuid())
  workflowId String
  type       String
  config     Json?
  order      Int

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}
